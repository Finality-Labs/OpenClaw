# Finality — chain (on-chain) configuration.
# Copy to .env in the repo root (or export these) to go LIVE on GOAT Network.
# Leave CHAIN_MODE=mock (or unset) for the default keyless behaviour.

# mock | live  — 'live' settles real transactions on GOAT.
CHAIN_MODE=mock

# goat-testnet (chainId 48816) | goat-mainnet (chainId 2345)
GOAT_NETWORK=goat-testnet

# RPC endpoint. Optional — defaults to the SDK's bundled RPC for the network:
#   goat-testnet -> https://rpc.testnet3.goat.network
#   goat-mainnet -> https://rpc.goat.network
# GOAT_RPC_URL=https://rpc.testnet3.goat.network

# REQUIRED for live: the settler/agent wallet private key (0x + 64 hex chars).
# This wallet signs the payment transfer + ERC-8004 feedback txs and must hold
# testnet gas (and the settle token, if GOAT_SETTLE_TOKEN is set).
# GOAT_PRIVATE_KEY=0x................................................................

# Optional: ERC-20 token to transfer as payment. Omit to settle in the native
# gas token via transferNative.
# GOAT_SETTLE_TOKEN=0x...
# GOAT_TOKEN_DECIMALS=6

# ERC-8004 registries (for reference; resolved by the SDK per network):
#   goat-testnet Identity   0x556089008Fc0a60cD09390Eca93477ca254A5522
#   goat-testnet Reputation 0xd9140951d8aE6E5F625a02F5908535e16e3af964
